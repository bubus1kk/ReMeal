<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReMealApp.ViewModels.Partner"
             x:Class="ReMealApp.Views.Partner.CreateLotView"
             x:DataType="vm:CreateLotViewModel">

    <Border Classes="card" MaxWidth="560" HorizontalAlignment="Left">
        <StackPanel Spacing="10">
            <TextBlock Text="Создание лота"
                       Classes="section-title"
                       IsVisible="{Binding IsCreateMode}"/>
            <TextBlock Text="Редактирование лота"
                       Classes="section-title"
                       IsVisible="{Binding IsEditMode}"/>

            <TextBlock Text="Сначала создайте активную точку питания на вкладке «Точка питания»."
                       TextWrapping="Wrap"
                       Foreground="OrangeRed"
                       IsVisible="{Binding HasNoFoodPoint}"/>

            <StackPanel Spacing="4">
                <TextBlock Text="Точка питания" Opacity="0.7" FontSize="12"/>
                <TextBox Text="{Binding FoodPointName}"
                         IsReadOnly="True"/>
            </StackPanel>

            <TextBox PlaceholderText="Название лота" Text="{Binding Title}"/>
            <TextBox PlaceholderText="Описание"
                     Text="{Binding Description}"
                     AcceptsReturn="True"
                     Height="72"/>
            <TextBox PlaceholderText="Состав" Text="{Binding Composition}"/>

            <Grid ColumnDefinitions="*,*">
                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,6,0">
                    <TextBlock Text="Количество" Opacity="0.7" FontSize="12"/>
                    <NumericUpDown Value="{Binding TotalQuantity}"
                                   Minimum="1"
                                   Increment="1"
                                   FormatString="0"
                                   IsEnabled="{Binding IsCreateMode}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4" Margin="6,0,0,0">
                    <TextBlock Text="Цена" Opacity="0.7" FontSize="12"/>
                    <NumericUpDown Value="{Binding Price}"
                                   Minimum="0"
                                   FormatString="0.00"/>
                </StackPanel>
            </Grid>

            <StackPanel Spacing="4">
                <TextBlock Text="Срок получения" Opacity="0.7" FontSize="12"/>
                <Grid ColumnDefinitions="*,*">
                    <DatePicker Grid.Column="0"
                                SelectedDate="{Binding PickupDeadline}"
                                Margin="0,0,6,0"/>
                    <TimePicker Grid.Column="1"
                                SelectedTime="{Binding PickupTime}"
                                Margin="6,0,0,0"/>
                </Grid>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Сохранить"
                        Command="{Binding SaveCommand}"/>
                <Button Content="Сбросить"
                        Command="{Binding ResetFormCommand}"/>
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       Opacity="0.8"/>
        </StackPanel>
    </Border>
</UserControl>
