<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReMealApp.ViewModels.Auth"
             x:Class="ReMealApp.Views.Auth.LoginView"
             x:DataType="vm:LoginViewModel">
    <UserControl.Styles>
        <Style Selector="TextBox.auth-input">
            <Setter Property="Height" Value="56"/>
            <Setter Property="Background" Value="#0F1715"/>
            <Setter Property="BorderBrush" Value="#31413B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Foreground" Value="#F3F7F0"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Padding" Value="16,0"/>
        </Style>

        <Style Selector="TextBox.auth-input:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#131D1A"/>
            <Setter Property="BorderBrush" Value="#3B5048"/>
        </Style>

        <Style Selector="TextBox.auth-input:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#17221F"/>
            <Setter Property="BorderBrush" Value="#5F8F4A"/>
        </Style>

        <Style Selector="Button.auth-tab">
            <Setter Property="Height" Value="54"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style Selector="Button.active-tab">
            <Setter Property="Background" Value="#203520"/>
            <Setter Property="BorderBrush" Value="#6FAF43"/>
            <Setter Property="Foreground" Value="#8FDB61"/>
        </Style>

        <Style Selector="Button.active-tab:pointerover">
            <Setter Property="Background" Value="#203520"/>
            <Setter Property="BorderBrush" Value="#6FAF43"/>
            <Setter Property="Foreground" Value="#8FDB61"/>
        </Style>

        <Style Selector="Button.active-tab:pressed">
            <Setter Property="Background" Value="#203520"/>
            <Setter Property="BorderBrush" Value="#6FAF43"/>
            <Setter Property="Foreground" Value="#8FDB61"/>
        </Style>

        <Style Selector="Button.inactive-tab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A9B8B0"/>
        </Style>

        <Style Selector="Button.inactive-tab:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A9B8B0"/>
        </Style>

        <Style Selector="Button.inactive-tab:pressed">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A9B8B0"/>
        </Style>

        <Style Selector="Button.text-link">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#86CF5B"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="FontSize" Value="17"/>
        </Style>

        <Style Selector="Button.text-link:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#86CF5B"/>
        </Style>

        <Style Selector="Button.text-link:pressed">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#86CF5B"/>
        </Style>

        <Style Selector="Button.primary-action">
            <Setter Property="Height" Value="62"/>
            <Setter Property="Background" Value="#43893A"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#F8FFF4"/>
            <Setter Property="FontSize" Value="21"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style Selector="Button.primary-action:pointerover">
            <Setter Property="Background" Value="#43893A"/>
            <Setter Property="Foreground" Value="#F8FFF4"/>
        </Style>

        <Style Selector="Button.primary-action:pressed">
            <Setter Property="Background" Value="#43893A"/>
            <Setter Property="Foreground" Value="#F8FFF4"/>
        </Style>

        <Style Selector="Button.password-action">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#B0C5B8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style Selector="Button.password-action:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0C5B8"/>
        </Style>

        <Style Selector="Button.password-action:pressed">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0C5B8"/>
        </Style>

        <Style Selector="Button.password-action:focus">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0C5B8"/>
        </Style>

        <Style Selector="TextBlock.field-label">
            <Setter Property="Foreground" Value="#DCE7DD"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#080D0C" Offset="0"/>
                <GradientStop Color="#0D1513" Offset="0.48"/>
                <GradientStop Color="#121A18" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid RowDefinitions="*,Auto"
              Margin="44,34,44,30">
            <Grid Grid.Row="0"
                  MaxWidth="1500"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  ColumnDefinitions="590,80,590">
                    <Grid Grid.Column="0"
                          Width="590"
                          RowDefinitions="Auto,Auto,Auto,Auto,*"
                          Margin="0,0,0,0"
                          VerticalAlignment="Center">
                        <Image Grid.Row="0"
                               Source="/Assets/Brand/remeal-logo.png"
                               Width="420"
                               Height="145"
                               HorizontalAlignment="Left"
                               Stretch="Uniform"
                               Margin="-54,-34,0,-18"/>

                        <StackPanel Grid.Row="1"
                                    Margin="0,18,0,0"
                                    Spacing="2">
                            <TextBlock Text="Сохраняем еду."
                                       Foreground="#F7FBF4"
                                       FontSize="39"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Снижаем отходы."
                                       Foreground="#F7FBF4"
                                       FontSize="39"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Получаем выгоду."
                                       Foreground="#8FD75E"
                                       FontSize="39"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2"
                                   Text="ReMeal помогает находить и бронировать готовые наборы еды по сниженной цене, чтобы хорошие блюда не отправлялись в отходы."
                                   Width="560"
                                   Margin="0,18,0,0"
                                   Foreground="#AEB9B1"
                                   FontSize="19"
                                   LineHeight="28"
                                   TextWrapping="Wrap"/>

                        <StackPanel Grid.Row="3"
                                    Margin="0,34,0,0"
                                    Spacing="12"
                                    VerticalAlignment="Top">
                            <Border CornerRadius="13"
                                    Padding="16"
                                    BorderBrush="#263A33"
                                    BorderThickness="1"
                                    Background="#141D1A">
                                <Grid ColumnDefinitions="42, *">
                                    <Border Width="34"
                                            Height="34"
                                            CornerRadius="10"
                                            Background="#213A25"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="+"
                                                   Foreground="#92D75E"
                                                   FontSize="21"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1"
                                                Spacing="3">
                                        <TextBlock Text="Экономьте на готовых наборах"
                                                   Foreground="#F3F7F0"
                                                   FontSize="17"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Бронируйте еду по сниженной цене."
                                                   Foreground="#9CA8A0"
                                                   FontSize="15"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border CornerRadius="13"
                                    Padding="16"
                                    BorderBrush="#263A33"
                                    BorderThickness="1"
                                    Background="#141D1A">
                                <Grid ColumnDefinitions="42, *">
                                    <Border Width="34"
                                            Height="34"
                                            CornerRadius="10"
                                            Background="#213A25"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="✓"
                                                   Foreground="#92D75E"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1"
                                                Spacing="3">
                                        <TextBlock Text="Помогайте сокращать отходы"
                                                   Foreground="#F3F7F0"
                                                   FontSize="17"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Хорошие блюда получают второй шанс."
                                                   Foreground="#9CA8A0"
                                                   FontSize="15"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border CornerRadius="13"
                                    Padding="16"
                                    BorderBrush="#263A33"
                                    BorderThickness="1"
                                    Background="#141D1A">
                                <Grid ColumnDefinitions="42, *">
                                    <Border Width="34"
                                            Height="34"
                                            CornerRadius="10"
                                            Background="#213A25"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="•"
                                                   Foreground="#92D75E"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1"
                                                Spacing="3">
                                        <TextBlock Text="Забирайте в удобное время"
                                                   Foreground="#F3F7F0"
                                                   FontSize="17"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Партнёры заранее указывают доступный интервал."
                                                   Foreground="#9CA8A0"
                                                   FontSize="15"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <Image Grid.Row="4"
                               Source="/Assets/Illustrations/auth-hero.png"
                               Width="410"
                               Height="270"
                               Margin="170,12,0,0"
                               HorizontalAlignment="Left"
                               Stretch="Uniform"/>
                    </Grid>

                    <Border Grid.Column="1"
                            Width="1"
                            Margin="34,28,45,28"
                            Background="#244037"/>

                    <Border Grid.Column="2"
                            Width="590"
                            MinHeight="680"
                            Padding="42"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            CornerRadius="22"
                            BorderBrush="#293833"
                            BorderThickness="1"
                            Background="#151C1A"
                            BoxShadow="0 24 70 0 #4D000000">
                        <Grid RowDefinitions="Auto,Auto,*">
                            <Border Grid.Row="0"
                                    Width="448"
                                    Height="62"
                                    HorizontalAlignment="Center"
                                    Padding="4"
                                    CornerRadius="15"
                                    BorderBrush="#32443E"
                                    BorderThickness="1"
                                    Background="#101716">
                                <Grid ColumnDefinitions="*,*">
                                    <Button Grid.Column="0"
                                            Classes="auth-tab active-tab"
                                            Content="Вход"
                                            IsVisible="{Binding IsLoginMode}"
                                            Command="{Binding ShowLoginCommand}"/>
                                    <Button Grid.Column="0"
                                            Classes="auth-tab inactive-tab"
                                            Content="Вход"
                                            IsVisible="{Binding IsRegisterMode}"
                                            Command="{Binding ShowLoginCommand}"/>

                                    <Button Grid.Column="1"
                                            Classes="auth-tab inactive-tab"
                                            Content="Регистрация"
                                            IsVisible="{Binding IsLoginMode}"
                                            Command="{Binding ShowRegisterCommand}"/>
                                    <Button Grid.Column="1"
                                            Classes="auth-tab active-tab"
                                            Content="Регистрация"
                                            IsVisible="{Binding IsRegisterMode}"
                                            Command="{Binding ShowRegisterCommand}"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1"
                                    Height="1"
                                    Margin="0,26,0,26"
                                    Background="#22312C"/>

                            <Grid Grid.Row="2">
                                <StackPanel IsVisible="{Binding IsLoginMode}"
                                            Spacing="18"
                                            Width="470"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <StackPanel Spacing="6"
                                                Margin="0,0,0,8">
                                        <TextBlock Text="Добро пожаловать"
                                                   Foreground="#F7FBF4"
                                                   FontSize="35"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Войдите в аккаунт, чтобы продолжить."
                                                   Foreground="#9EA9A2"
                                                   FontSize="19"/>
                                    </StackPanel>

                                    <StackPanel Spacing="7">
                                        <TextBlock Classes="field-label"
                                                   Text="Логин"/>
                                        <TextBox Classes="auth-input"
                                                 PlaceholderText="Введите логин"
                                                 MaxLength="100"
                                                 Text="{Binding Login, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="7">
                                        <TextBlock Classes="field-label"
                                                   Text="Пароль"/>
                                        <Grid>
                                            <TextBox Classes="auth-input"
                                                     PlaceholderText="Введите пароль"
                                                     PasswordChar="*"
                                                     MaxLength="100"
                                                     Padding="16,0,88,0"
                                                     IsVisible="{Binding IsPasswordHidden}"
                                                     Text="{Binding Password, Mode=TwoWay}"/>
                                            <TextBox Classes="auth-input"
                                                     PlaceholderText="Введите пароль"
                                                     MaxLength="100"
                                                     Padding="16,0,88,0"
                                                     IsVisible="{Binding IsPasswordVisible}"
                                                     Text="{Binding Password, Mode=TwoWay}"/>
                                            <Button Classes="password-action"
                                                    Content="{Binding PasswordVisibilityText}"
                                                    Command="{Binding TogglePasswordVisibilityCommand}"
                                                    Focusable="False"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,8,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <Grid ColumnDefinitions="*,Auto"
                                          Margin="0,2,0,8">
                                        <CheckBox Content="Запомнить меня"
                                                  IsChecked="{Binding RememberMe, Mode=TwoWay}"
                                                  Foreground="#D8E2DA"
                                                  FontSize="17"/>
                                        <Button Grid.Column="1"
                                                Classes="text-link"
                                                Content="Забыли пароль?"/>
                                    </Grid>

                                    <TextBlock Text="{Binding ErrorMessage}"
                                               Foreground="#FF8F8F"
                                               FontSize="15"
                                               TextWrapping="Wrap"/>

                                    <Button Classes="primary-action"
                                            Content="Войти"
                                            Command="{Binding LoginCommand}"
                                            HorizontalAlignment="Stretch"/>

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Margin="0,12,0,0">
                                        <TextBlock Text="Нет аккаунта?"
                                                   Foreground="#9EA9A2"
                                                   FontSize="17"
                                                   VerticalAlignment="Center"/>
                                        <Button Classes="text-link"
                                                Content="Зарегистрироваться"
                                                Command="{Binding ShowRegisterCommand}"/>
                                    </StackPanel>
                                </StackPanel>

                                <ScrollViewer IsVisible="{Binding IsRegisterMode}"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Spacing="12"
                                            Width="470"
                                            HorizontalAlignment="Center">
                                    <StackPanel Spacing="6"
                                                Margin="0,0,0,6">
                                        <TextBlock Text="Создайте аккаунт"
                                                   Foreground="#F7FBF4"
                                                   FontSize="35"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Заполните данные, чтобы начать пользоваться ReMeal."
                                                   Foreground="#9EA9A2"
                                                   FontSize="19"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Spacing="7">
                                        <TextBlock Classes="field-label"
                                                   Text="Логин"/>
                                        <TextBox Classes="auth-input"
                                                 PlaceholderText="Введите логин"
                                                 MaxLength="100"
                                                 Text="{Binding Login, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="7">
                                        <TextBlock Classes="field-label"
                                                   Text="ФИО"/>
                                        <TextBox Classes="auth-input"
                                                 PlaceholderText="Введите ФИО"
                                                 MaxLength="100"
                                                 Text="{Binding Name, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="7">
                                        <TextBlock Classes="field-label"
                                                   Text="Электронная почта"/>
                                        <TextBox Classes="auth-input"
                                                 PlaceholderText="Введите email"
                                                 MaxLength="100"
                                                 Text="{Binding Email, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="7">
                                        <TextBlock Classes="field-label"
                                                   Text="Телефон"/>
                                        <TextBox Classes="auth-input"
                                                 PlaceholderText="Введите телефон"
                                                 MaxLength="100"
                                                 Text="{Binding Phone, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="7">
                                        <TextBlock Classes="field-label"
                                                   Text="Роль"/>
                                        <ComboBox Height="56"
                                                  CornerRadius="12"
                                                  Background="#0F1715"
                                                  BorderBrush="#31413B"
                                                  Foreground="#F3F7F0"
                                                  FontSize="16"
                                                  ItemsSource="{Binding Roles}"
                                                  SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                                  HorizontalAlignment="Stretch"/>
                                    </StackPanel>

                                    <StackPanel Spacing="7">
                                        <TextBlock Classes="field-label"
                                                   Text="Пароль"/>
                                        <Grid>
                                            <TextBox Classes="auth-input"
                                                     PlaceholderText="Создайте пароль"
                                                     PasswordChar="*"
                                                     MaxLength="100"
                                                     Padding="16,0,88,0"
                                                     IsVisible="{Binding IsPasswordHidden}"
                                                     Text="{Binding Password, Mode=TwoWay}"/>
                                            <TextBox Classes="auth-input"
                                                     PlaceholderText="Создайте пароль"
                                                     MaxLength="100"
                                                     Padding="16,0,88,0"
                                                     IsVisible="{Binding IsPasswordVisible}"
                                                     Text="{Binding Password, Mode=TwoWay}"/>
                                            <Button Classes="password-action"
                                                    Content="{Binding PasswordVisibilityText}"
                                                    Command="{Binding TogglePasswordVisibilityCommand}"
                                                    Focusable="False"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,8,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Spacing="7">
                                        <TextBlock Classes="field-label"
                                                   Text="Подтвердите пароль"/>
                                        <Grid>
                                            <TextBox Classes="auth-input"
                                                     PlaceholderText="Повторите пароль"
                                                     PasswordChar="*"
                                                     MaxLength="100"
                                                     Padding="16,0,88,0"
                                                     IsVisible="{Binding IsConfirmPasswordHidden}"
                                                     Text="{Binding ConfirmPassword, Mode=TwoWay}"/>
                                            <TextBox Classes="auth-input"
                                                     PlaceholderText="Повторите пароль"
                                                     MaxLength="100"
                                                     Padding="16,0,88,0"
                                                     IsVisible="{Binding IsConfirmPasswordVisible}"
                                                     Text="{Binding ConfirmPassword, Mode=TwoWay}"/>
                                            <Button Classes="password-action"
                                                    Content="{Binding ConfirmPasswordVisibilityText}"
                                                    Command="{Binding ToggleConfirmPasswordVisibilityCommand}"
                                                    Focusable="False"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,8,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <CheckBox Content="Я принимаю условия использования и политику конфиденциальности"
                                              IsChecked="{Binding AcceptedTerms, Mode=TwoWay}"
                                              Foreground="#D8E2DA"
                                              FontSize="16"/>

                                    <TextBlock Text="{Binding ErrorMessage}"
                                               Foreground="#FF8F8F"
                                               FontSize="15"
                                               TextWrapping="Wrap"/>

                                    <Button Classes="primary-action"
                                            Content="Зарегистрироваться"
                                            Command="{Binding RegisterCommand}"
                                            HorizontalAlignment="Stretch"/>

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Margin="0,8,0,0">
                                        <TextBlock Text="Уже есть аккаунт?"
                                                   Foreground="#9EA9A2"
                                                   FontSize="17"
                                                   VerticalAlignment="Center"/>
                                        <Button Classes="text-link"
                                                Content="Войти"
                                                Command="{Binding ShowLoginCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
            </Grid>

            <TextBlock Grid.Row="1"
                       Margin="0,20,0,0"
                       Text="Ваши данные защищены и не передаются третьим лицам."
                       Foreground="#7F8E84"
                       FontSize="13"
                       HorizontalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>
