<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReMealApp.ViewModels.Catalog"
             xmlns:conv="using:ReMealApp.Converters"
             xmlns:ent="using:Domain.Entities"
             x:Class="ReMealApp.Views.Catalog.CatalogView"
             x:DataType="vm:CatalogViewModel">

    <UserControl.Resources>
        <conv:LotStatusToTextConverter x:Key="LotStatusConverter"/>
    </UserControl.Resources>

    <Border Classes="card">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top"
                        Orientation="Horizontal"
                        Spacing="8"
                        Margin="0,0,0,12">
                <TextBlock Text="Доступные пищевые наборы"
                           Classes="section-title"/>
                <Button Content="Обновить"
                        Command="{Binding LoadCommand}"/>
            </StackPanel>

            <TextBlock DockPanel.Dock="Bottom"
                       Text="{Binding StatusMessage}"
                       Margin="0,12,0,0"
                       TextWrapping="Wrap"
                       Opacity="0.8"/>

            <DataGrid ItemsSource="{Binding Lots}"
                      IsReadOnly="True"
                      AutoGenerateColumns="False"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Набор" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="Точка питания" Binding="{Binding FoodPoint.Name}" Width="*"/>
                    <DataGridTextColumn Header="Адрес" Binding="{Binding FoodPoint.Address}" Width="2*"/>
                    <DataGridTextColumn Header="Состав" Binding="{Binding Composition}" Width="2*"/>
                    <DataGridTextColumn Header="Доступно" Binding="{Binding AvailableQuantity}" Width="90"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:N2}}" Width="90"/>
                    <DataGridTemplateColumn Header="Статус" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="ent:FoodLot">
                                <TextBlock Text="{Binding Status, Converter={StaticResource LotStatusConverter}, Mode=OneWay}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Получить до"
                                        Binding="{Binding PickupDeadline, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                        Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
