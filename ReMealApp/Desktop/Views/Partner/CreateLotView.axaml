<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReMeal.Desktop.ViewModels.Partner"
             xmlns:ent="using:ReMeal.Domain.Entities"
             x:Class="ReMeal.Desktop.Views.Partner.CreateLotView"
             x:DataType="vm:CreateLotViewModel">

    <Border Classes="card" MaxWidth="560" HorizontalAlignment="Left">
        <StackPanel Spacing="10">
            <TextBlock Text="Создание лота"
                       Classes="section-title"
                       IsVisible="{Binding !IsEditMode}"/>
            <TextBlock Text="Редактирование лота"
                       Classes="section-title"
                       IsVisible="{Binding IsEditMode}"/>

            <TextBlock Text="Сначала создайте точку питания на вкладке «Точки питания»."
                       TextWrapping="Wrap"
                       Foreground="OrangeRed"
                       IsVisible="{Binding HasNoFoodPoints}"/>

            <StackPanel Spacing="4">
                <TextBlock Text="Точка питания" Opacity="0.7" FontSize="12"/>
                <ComboBox ItemsSource="{Binding FoodPoints}"
                          SelectedValue="{Binding SelectedFoodPointId}"
                          SelectedValueBinding="{Binding Id}"
                          HorizontalAlignment="Stretch"
                          MinWidth="200"
                          MinHeight="36"
                          IsEnabled="{Binding !IsEditMode}"
                          PlaceholderText="Выберите точку">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="ent:FoodPoint">
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <TextBox Watermark="Название лота" Text="{Binding Title}"/>
            <TextBox Watermark="Описание"
                     Text="{Binding Description}"
                     AcceptsReturn="True"
                     Height="72"/>
            <TextBox Watermark="Состав" Text="{Binding Composition}"/>

            <Grid ColumnDefinitions="*,*">
                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,6,0">
                    <TextBlock Text="Количество" Opacity="0.7" FontSize="12"/>
                    <NumericUpDown Value="{Binding TotalQuantity}"
                                   Minimum="1"
                                   IsEnabled="{Binding !IsEditMode}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4" Margin="6,0,0,0">
                    <TextBlock Text="Цена" Opacity="0.7" FontSize="12"/>
                    <NumericUpDown Value="{Binding Price}"
                                   Minimum="0"
                                   FormatString="0.00"/>
                </StackPanel>
            </Grid>

            <StackPanel Spacing="4">
                <TextBlock Text="Срок получения" Opacity="0.7" FontSize="12"/>
                <DatePicker SelectedDate="{Binding PickupDeadline}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Сохранить"
                        Command="{Binding SaveCommand}"/>
                <Button Content="Сбросить"
                        Command="{Binding ResetFormCommand}"/>
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       Opacity="0.8"/>
        </StackPanel>
    </Border>
</UserControl>
