<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ReMeal.Desktop.ViewModels"
        xmlns:partner="using:ReMeal.Desktop.Views.Partner"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="ReMeal.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ReMeal"
        Width="1100"
        Height="720"
        MinWidth="900"
        MinHeight="600">

    <Grid RowDefinitions="Auto,*" Margin="16">
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="ReMeal" Classes="section-title" FontSize="22"/>
            <TextBlock Text="Модуль партнёра: точки питания и лоты"
                       Opacity="0.7"/>
        </StackPanel>

        <TabControl Grid.Row="1"
                    SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Точки питания">
                <partner:FoodPointView DataContext="{Binding FoodPoints}"/>
            </TabItem>
            <TabItem Header="Лоты">
                <partner:PartnerLotsView DataContext="{Binding PartnerLots}"/>
            </TabItem>
            <TabItem Header="Создать / редактировать лот">
                <partner:CreateLotView DataContext="{Binding CreateLot}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
